{
  "defaultTarget": "staging",
  "targets": {
    "staging": {
      "host": "staging.example.com",
      "username": "deploy-user",
      "privateKeyPath": "~/.ssh/id_ed25519",
      "remotePath": "/var/www/staging",
      "uploadOnSave": true,
      "proxy": {
        "type": "socks5",
        "host": "127.0.0.1",
        "port": 1080
      }
    },
    "production": {
      "host": "prod.example.com",
      "username": "admin",
      "privateKeyPath": "C:/Users/User/.ssh/id_rsa", 
      "passphrase": true, 
      "remotePath": "/var/www/prod",
      "uploadOnSave": false
    }
  }
}